# IntegrationOps — environment configuration template.
# Copy to `.env` and adjust for your local setup. Never commit a real `.env`.

# Application
ENVIRONMENT=development
DEBUG=true

# PostgreSQL (used from Phase 2 onward)
DATABASE_URL=postgresql+psycopg://integrationops:integrationops@db:5432/integrationops

# Redis (used from Phase 5 onward)
REDIS_URL=redis://redis:6379/0

# Security / JWT — generate a strong value, e.g. `openssl rand -hex 32`
SECRET_KEY=dev-insecure-secret-change-me
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# Celery / async processing (defaults to REDIS_URL when unset)
# CELERY_BROKER_URL=redis://redis:6379/0
# CELERY_RESULT_BACKEND=redis://redis:6379/0
CELERY_TASK_ALWAYS_EAGER=false
JOB_RETRY_COUNTDOWN_SECONDS=5

# Exports & webhooks
EXPORT_DIR=exports
WEBHOOK_TIMEOUT_SECONDS=10
